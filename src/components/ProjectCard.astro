---
interface Props {
  title: string;
  tagline: string;
  description: string;
  image: string;
  imageAlt: string;
  href: string;
  chips: string[];
  accent?: string; // tailwind text color class for the tagline
  links?: { label: string; href: string }[];
}

const {
  title,
  tagline,
  description,
  image,
  imageAlt,
  href,
  chips,
  accent = 'text-indigo-600 dark:text-indigo-400',
  links = [],
} = Astro.props;
---

<article class="card flex flex-col overflow-hidden">
  <a href={href} class="block overflow-hidden border-b border-zinc-950/5 bg-zinc-100 dark:border-white/5 dark:bg-zinc-800">
    <img
      src={image}
      alt={imageAlt}
      loading="lazy"
      class="aspect-[16/10] w-full object-cover object-top transition duration-300 hover:scale-[1.02]"
    />
  </a>
  <div class="flex flex-1 flex-col p-6">
    <p class={`text-xs font-bold uppercase tracking-wide ${accent}`}>{tagline}</p>
    <h3 class="mt-1.5 text-xl font-bold tracking-tight text-zinc-900 dark:text-white">
      <a href={href} class="hover:underline underline-offset-4">{title}</a>
    </h3>
    <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">{description}</p>
    <div class="mt-4 flex flex-wrap gap-1.5">
      {chips.map((c) => <span class="chip">{c}</span>)}
    </div>
    <div class="mt-5 flex flex-wrap items-center gap-4 border-t border-zinc-950/5 pt-4 text-sm font-semibold dark:border-white/5">
      <a href={href} class="link">Read the case study →</a>
      {links.map((l) => (
        <a href={l.href} target="_blank" rel="noopener" class="text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white">
          {l.label} ↗
        </a>
      ))}
    </div>
  </div>
</article>
