---
interface Props {
  title: string;
  tagline: string;
  intro: string;
  accent?: string;
  facts: { label: string; value: string }[];
  ctas: { label: string; href: string; primary?: boolean }[];
}
const { title, tagline, intro, facts, ctas, accent = 'text-indigo-600 dark:text-indigo-400' } = Astro.props;
---

<div class="mx-auto max-w-3xl px-6 pt-16">
  <p class={`text-sm font-bold uppercase tracking-wide ${accent}`}>{tagline}</p>
  <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-zinc-900 dark:text-white sm:text-5xl">
    {title}
  </h1>
  <p class="mt-5 text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">{intro}</p>

  <div class="mt-7 flex flex-wrap items-center gap-3">
    {ctas.map((c) => (
      <a
        href={c.href}
        target={c.href.startsWith('http') ? '_blank' : undefined}
        rel={c.href.startsWith('http') ? 'noopener' : undefined}
        class={c.primary ? 'btn-primary' : 'btn-secondary'}
      >
        {c.label}
      </a>
    ))}
  </div>

  <dl class="mt-10 grid grid-cols-2 gap-4 rounded-2xl bg-white p-5 ring-1 ring-zinc-950/5 sm:grid-cols-4 dark:bg-zinc-900 dark:ring-white/10">
    {facts.map((f) => (
      <div>
        <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-400">{f.label}</dt>
        <dd class="mt-1 text-sm font-semibold text-zinc-900 dark:text-white">{f.value}</dd>
      </div>
    ))}
  </dl>
</div>
